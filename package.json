{
  "name": "todo-electron",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev:next": "next dev --turbopack -p 3000",
    "dev:electron": "electron .",
"dev": "concurrently -n next,electron -c green,blue \"npm:dev:next\" \"wait-on http-get://localhost:3000 && electron .\"",
    "build:next": "next build --turbopack && next export",
    "build:electron": "electron-builder --win --dir",
    "build": "npm run build:next && npm run build:electron",
    "dist": "electron-builder --win --x64",
    "start": "next start",
    "lint": "eslint"
  },
  "build": {
    "appId": "com.example.todoelectron",
    "productName": "Todo Electron",
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "extraMetadata": {
      "main": "electron/main.js"
    }
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "next": "16.1.5"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "@eslint/eslintrc": "^3",
    "concurrently": "^9",
    "electron": "^35",
    "electron-builder": "^26",
    "wait-on": "^7"
  }
}
